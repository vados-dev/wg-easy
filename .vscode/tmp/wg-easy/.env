#TAG=reg.vados.ru/wg-easy/wg-easy:15 docker compose build
#TAG=reg.vados.ru/wg-easy/wg-easy:lts docker compose build
LANG=ru
# .. Required:
# Change this to your host's public address
# - WG_HOST=89.110.101.17
#WG_HOST=10.30.30.33
#HOST=10.30.30.33
# Optional:
# - PASSWORD_HASH=$$2y$$10$$hBCoykrB95WSzuV4fafBzOHWKu9sbyVa34GJr8VV5R/pIelfEMYyG # (needs double $$, hash of 'foobar123'; see "How_to_generate_an_bcrypt_hash.md" for generate the hash)
#PASSWORD_HASH=$$2a$12$5sWStJ8xjBrDJNY.0TJye.ENJ5Ml9wL.1MnTB7E7284P83RpXQ7SW
# - PORT=51821
PORT=8588
# - WG_PORT=51820
WG_PORT=29185
#WG_CONFIG_PORT=92820
WG_DEFAULT_ADDRESS=10.42.42.42
#WG_DEFAULT_DNS=1.1.1.1
WG_DEFAULT_DNS=8.8.8.8, 1.1.1.1
WG_MTU=1420
WG_ALLOWED_IPS=10.8.0.0/24
#, 10.0.1.0/24
WG_PERSISTENT_KEEPALIVE=25
# - WG_PRE_UP=echo "Pre Up" > /etc/wireguard/pre-up.txt
WG_POST_UP=/etc/wireguard/post-up.txt
# - WG_PRE_DOWN=echo "Pre Down" > /etc/wireguard/pre-down.txt
WG_POST_DOWN=/etc/wireguard/post-down.txt
UI_TRAFFIC_STATS=true
UI_CHART_TYPE=3 # (0 Charts disabled, 1 # Line chart, 2 # Area chart, 3 # Bar chart)
INSECURE=true
INIT_ENABLED=false
DISABLE_IPV6=true
# Unattended Setup
INIT_ENABLED=true
INIT_USERNAME=vados
INIT_PASSWORD=nsWw1bHHiK828ue9
# Replace $example.com$ with your domain
INIT_HOST=amster.vados.ru
INIT_PORT=8588
INIT_DNS=10.42.42.43
INIT_IPV4_CIDR=10.8.0.0/24
